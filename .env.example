# ChadWallet — environment variables
# Copy to `.env.local` for local dev, or paste into Vercel → Project → Settings → Environment Variables.
# Every service below has a free tier. The app runs WITHOUT any of these (it
# shows realistic preview data); add them to switch on live markets + auth.

# ── BirdEye (market data: trending, prices, charts, trades, holders) ──
# Free key: https://birdeye.so/data-api  →  Dashboard → API Keys
# Server-only. Never exposed to the browser.
BIRDEYE_API_KEY=

# ── Privy (sign in with Apple / Google, embedded self-custodial wallet) ──
# Free app: https://dashboard.privy.io  →  create app → copy App ID
# This one is public (client-side) by design — that's how Privy works.
NEXT_PUBLIC_PRIVY_APP_ID=

# ── Alchemy (Solana RPC: balances + transaction simulation) ──
# Free key: https://www.alchemy.com  →  create app on Solana Mainnet → copy URL
# Server-only.
ALCHEMY_RPC_URL=

# Jupiter (swap quotes) needs NO key — its public quote API is used directly.
